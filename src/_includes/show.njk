---
layout: base.njk
generateShowSchema: false
---

{%- for st in showtimes %}
<!-- Event Schema for {{ st.startDate | showTimeOnly }} showtime -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "{{ title }}{% if subtitle %} {{ subtitle }}{% endif %}",
    "startDate": "{{ st.startDate | isoDate }}",
    "endDate": "{{ st.endDate | isoDate }}",
    "eventStatus": "{{ eventStatus }}",
    "eventAttendanceMode": "{{ eventAttendanceMode }}",
    "location": {
        "@type": "Place",
        "name": "{{ location.name }}",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "{{ location.streetAddress }}",
            "addressLocality": "{{ location.city }}",
            "addressRegion": "{{ location.state }}",
            "postalCode": "{{ location.postalCode }}",
            "addressCountry": "{{ location.country }}"
        }
    },
    "description": "{{ description | replace('"', '\\"') }}",
    "organizer": {
        "@type": "Organization",
        "name": "{{ organizerName }}",
        "url": "{{ organizerUrl }}"
    }{% if images and images.length %},
    "image": [{% for img in images %}"https://misconductcomedy.com{{ img.src }}"{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}{% if st.ticketUrl or st.ticketPrice %},
    "offers": {
        "@type": "Offer",
        "url": "{{ st.ticketUrl or 'https://misconductcomedy.com' }}",
        "availability": "{{ st.ticketAvailability }}"{% if st.ticketPrice %},
        "price": "{{ st.ticketPrice }}",
        "priceCurrency": "{{ priceCurrency }}"{% endif %}{% if ticketSaleStart %},
        "validFrom": "{{ ticketSaleStart | isoDate }}"{% endif %}
    }{% endif %}{% if performers and performers.length %},
    "performer": [{% for p in performers %}{"@type": "Person", "name": "{{ p.name }}"}{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}
}
</script>
{%- endfor %}

<!-- Breadcrumb Schema -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Misconduct Comedy",
            "item": "https://misconductcomedy.com/"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Shows",
            "item": "https://misconductcomedy.com/#shows"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ title }}"
        }
    ]
}
</script>

<div class="show-detail">
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span class="breadcrumb-sep">&rsaquo;</span> <a href="/#shows">Shows</a> <span class="breadcrumb-sep">&rsaquo;</span> <span>{{ title }}</span>
    </nav>

    {% if images and images.length > 0 %}
    <div class="carousel">
        <div class="carousel-track">
            {% for img in images %}
            <div class="carousel-slide{% if loop.first %} active{% endif %}">
                <img src="{{ img.src }}" alt="{{ img.alt or title }} - Live Stand-Up Comedy at {{ location.name }} in Philadelphia">
            </div>
            {% endfor %}
        </div>
        {% if images.length > 1 %}
        <button class="carousel-btn carousel-prev" aria-label="Previous image">&#10094;</button>
        <button class="carousel-btn carousel-next" aria-label="Next image">&#10095;</button>
        <div class="carousel-dots">
            {% for img in images %}
            <span class="carousel-dot{% if loop.first %} active{% endif %}" data-index="{{ loop.index0 }}"></span>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endif %}

    <h1>{{ title }}{% if subtitle %}<br><span class="show-page-subtitle">{{ subtitle }}</span>{% endif %}</h1>

    <div class="show-detail-meta">
        <p class="show-detail-date">
            {{ showtimes[0].startDate | showDateOnly }} • {% for st in showtimes %}{{ st.startDate | showTimeOnly }}{% if not loop.last %} &amp; {% endif %}{% endfor %}
        </p>
        <span class="show-tag">{{ showtimes[0].startDate | showDayOfWeek }}</span>
        {% if showType %}<span class="show-tag">{{ showType }}</span>{% endif %}
        {% if ageRestriction %}<span class="show-tag">{{ ageRestriction }}</span>{% endif %}
    </div>

    <div class="show-detail-info">
        <div class="show-detail-description">
            <h2>About This {{ showType or 'Show' }}</h2>
            <div class="description-content">{{ description | safe }}</div>
            {{ content | safe }}

            <div class="show-seo-content">
                <h2>Live Stand-Up Comedy in Philadelphia</h2>
                <p>Join us for an unforgettable evening of live stand-up comedy at {{ location.name }} in the heart of Center City Philadelphia. {{ title }}{% if subtitle %} {{ subtitle }}{% endif %} is the perfect choice for date night, a fun night out with friends, or anyone seeking the best comedy shows in Philadelphia. Located at {{ location.streetAddress }}, our intimate venue offers a cozy atmosphere paired with great food and drinks for an incredible live entertainment experience.</p>
            </div>
        </div>

        <div class="show-detail-sidebar">
            <div class="detail-block tickets-block">
                <h3>🎟️ Get Tickets</h3>
                {% for st in showtimes %}
                    {% if st.ticketAvailability == "https://schema.org/InStock" and st.ticketUrl %}
                    <a href="{{ st.ticketUrl }}" class="btn-tickets" target="_blank" rel="noopener" onclick="gtag('event', 'ticket_click', {'event_category': 'Tickets', 'event_label': '{{ title }} {{ st.startDate | showTimeOnly }}', 'transport_type': 'beacon'});">BUY {{ st.startDate | showTimeOnly }} TICKETS</a>
                    {% elif st.ticketAvailability == "https://schema.org/PreOrder" %}
                    <span class="coming-soon">{{ st.startDate | showTimeOnly }} — COMING SOON</span>
                    {% elif st.ticketAvailability == "https://schema.org/SoldOut" %}
                    <span class="coming-soon">{{ st.startDate | showTimeOnly }} — SOLD OUT</span>
                    {% else %}
                    <span class="coming-soon">COMING SOON</span>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="detail-block">
                <h3>📍 Venue</h3>
                <p><strong>{{ location.name }}</strong></p>
                <p><a href="https://maps.google.com/?q={{ location.streetAddress | urlencode }},+{{ location.city | urlencode }}+{{ location.state }}+{{ location.postalCode }}" target="_blank" rel="noopener" class="venue-address">{{ location.streetAddress }}, {{ location.city }} {{ location.state }} {{ location.postalCode }}</a></p>
            </div>

            {% if performers and performers.length %}
            <div class="detail-block">
                <h3>🎭 Performers</h3>
                <div class="performers-list">
                    {% for p in performers %}
                    <div class="performer-item">
                        {% if p.photo %}
                        <img src="{{ p.photo }}" alt="{{ p.name }} - Stand-Up Comedian at Misconduct Comedy Philadelphia" class="performer-photo">
                        {% endif %}
                        <div class="performer-info">
                            <p class="performer-name">{{ p.name }}</p>
                            {% if p.instagram %}
                            <a href="{{ p.instagram }}" target="_blank" rel="noopener" class="performer-ig">@{{ p.instagram | replace('https://instagram.com/', '') | replace('https://www.instagram.com/', '') | replace('/', '') }}</a>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <div class="detail-block">
                <h3>📋 Show Details</h3>
                {% if ageRestriction %}<p><strong>Age:</strong> {{ ageRestriction }}</p>{% endif %}
                <p><strong>Seating:</strong> First come, first served</p>
                <p><strong>Doors:</strong> 30 minutes before showtime</p>
                <p><strong>Duration:</strong> 75-90 minutes</p>
                <p><strong>Minimum:</strong> 2-item minimum (food &amp; drinks available)</p>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var track = document.querySelector('.carousel-track');
    if (!track) return;

    var slides = track.querySelectorAll('.carousel-slide');
    var dots = document.querySelectorAll('.carousel-dot');
    var prevBtn = document.querySelector('.carousel-prev');
    var nextBtn = document.querySelector('.carousel-next');
    var current = 0;

    function goTo(index) {
        slides[current].classList.remove('active');
        if (dots.length) dots[current].classList.remove('active');
        current = (index + slides.length) % slides.length;
        slides[current].classList.add('active');
        if (dots.length) dots[current].classList.add('active');
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });
    for (var i = 0; i < dots.length; i++) {
        dots[i].addEventListener('click', function() { goTo(parseInt(this.dataset.index)); });
    }
})();
</script>
