---
layout: base.njk
generateShowSchema: false
stylesheet: show.css
bodyClass: home2-page
---

{%- for st in showtimes %}
<!-- Event Schema for {{ st.startDate | showTimeOnly }} showtime -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "{{ title }}{% if subtitle %} {{ subtitle }}{% endif %}",
    "startDate": "{{ st.startDate | isoDate }}",
    "endDate": "{{ st.endDate | isoDate }}",
    "eventStatus": "{{ eventStatus }}",
    "eventAttendanceMode": "{{ eventAttendanceMode }}",
    "location": {
        "@type": "Place",
        "name": "{{ location.name }}",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "{{ location.streetAddress }}",
            "addressLocality": "{{ location.city }}",
            "addressRegion": "{{ location.state }}",
            "postalCode": "{{ location.postalCode }}",
            "addressCountry": "{{ location.country }}"
        }
    },
    "description": "{{ description | replace('"', '\\"') }}",
    "organizer": {
        "@type": "Organization",
        "name": "{{ organizerName }}",
        "url": "{{ organizerUrl }}"
    }{% if images and images.length %},
    "image": [{% for img in images %}"https://misconductcomedy.com{{ img.src }}"{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}{% if st.ticketUrl or st.ticketPrice %},
    "offers": {
        "@type": "Offer",
        "url": "{{ st.ticketUrl or 'https://misconductcomedy.com' }}",
        "availability": "{{ st.ticketAvailability }}"{% if st.ticketPrice %},
        "price": "{{ st.ticketPrice }}",
        "priceCurrency": "{{ priceCurrency }}"{% endif %}{% if ticketSaleStart %},
        "validFrom": "{{ ticketSaleStart | isoDate }}"{% endif %}
    }{% endif %}{% if performers and performers.length %},
    "performer": [{% for p in performers %}{"@type": "Person", "name": "{{ p.name }}"}{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}
}
</script>
{%- endfor %}

<!-- Breadcrumb Schema -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Misconduct Comedy",
            "item": "https://misconductcomedy.com/"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Shows",
            "item": "https://misconductcomedy.com/#shows"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ title }}"
        }
    ]
}
</script>

<div class="h2-page sp-page">

  <!-- Nav -->
  {%- set navLinks %}<li><a href="/" class="h2-nav-link">Home</a></li><li><a href="/#shows" class="h2-nav-link">Shows</a></li>{% endset -%}
  {%- include "h2-nav.njk" -%}

  <!-- Hero -->
  <div class="sp-hero">
    {%- if images and images.length -%}
    <div class="sp-hero-img-wrap">
      <img src="{{ images[0].src | netlifyImg(1920) }}" alt="{{ images[0].alt or title }}" class="sp-hero-img" loading="eager" decoding="async">
      <div class="sp-hero-img-overlay" aria-hidden="true"></div>
    </div>
    {%- endif -%}

    <div class="sp-hero-content">
      <!-- Breadcrumb -->
      <nav class="sp-breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="sp-breadcrumb-link">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#shows" class="sp-breadcrumb-link">Shows</a>
        <span aria-hidden="true">/</span>
        <span class="sp-breadcrumb-current">{{ title }}</span>
      </nav>

      <div class="mc-topper">
        <div class="mc-topper-rule" aria-hidden="true"></div>
        <span class="mc-topper-text">{{ showType or 'Live Stand-Up' }} &middot; Philadelphia</span>
      </div>

      <h1 class="sp-title">{{ title }}</h1>
      {%- if subtitle -%}<p class="sp-subtitle">{{ subtitle }}</p>{%- endif -%}

      <div class="sp-hero-meta">
        <div class="sp-meta-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {{ showtimes[0].startDate | showDayOfWeek }}, {{ showtimes[0].startDate | showDateOnly }}
        </div>
        <div class="sp-meta-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {%- for st in showtimes -%}{{ st.startDate | showTimeOnly }}{% if not loop.last %} &amp; {% endif %}{%- endfor -%}
        </div>
        <div class="sp-meta-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          {{ location.name }}
        </div>
        {%- if ageRestriction -%}
        <div class="sp-meta-pill">{{ ageRestriction }}</div>
        {%- endif -%}
      </div>

      <!-- Ticket CTAs -->
      <div class="sp-hero-tickets">
        {%- for st in showtimes -%}
          {%- if st.ticketAvailability == "https://schema.org/InStock" and st.ticketUrl -%}
          <a
            href="{{ st.ticketUrl }}"
            class="h2-ticket-btn h2-ticket-btn--featured"
            target="_blank"
            rel="noopener"
            onclick="gtag('event', 'ticket_click', {'event_category': 'Tickets', 'event_label': '{{ title }} {{ st.startDate | showTimeOnly }}', 'transport_type': 'beacon'});"
          >Get Tickets {{ st.startDate | showTimeOnly }} &rarr;</a>
          {%- elif st.ticketAvailability == "https://schema.org/SoldOut" -%}
          <span class="h2-ticket-unavailable">{{ st.startDate | showTimeOnly }} &mdash; Sold Out</span>
          {%- else -%}
          <span class="h2-ticket-unavailable">Coming Soon</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div><!-- /.sp-hero -->

  <!-- Body -->
  <div class="sp-body">
    <div class="sp-body-inner">

      <!-- Main column -->
      <main class="sp-main">

        <!-- Photo carousel -->
        {%- if images and images.length > 1 -%}
        <section class="sp-carousel" aria-label="Show photos">
          <div class="sp-carousel-track" aria-live="polite">
            {%- for img in images -%}
            <div class="sp-carousel-slide{% if loop.first %} is-active{% endif %}" aria-hidden="{% if loop.first %}false{% else %}true{% endif %}">
              <img src="{{ img.src | netlifyImg(1400) }}" alt="{{ img.alt or title }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}" decoding="async">
            </div>
            {%- endfor -%}
          </div>
          <button class="sp-carousel-btn sp-carousel-btn--prev" aria-label="Previous photo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="sp-carousel-btn sp-carousel-btn--next" aria-label="Next photo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          <div class="sp-carousel-dots" role="tablist" aria-label="Photo navigation">
            {%- for img in images -%}
            <button class="sp-carousel-dot{% if loop.first %} is-active{% endif %}" role="tab" aria-label="Photo {{ loop.index }}" aria-selected="{% if loop.first %}true{% else %}false{% endif %}" data-index="{{ loop.index0 }}"></button>
            {%- endfor -%}
          </div>
        </section>
        {%- endif -%}

        <!-- About -->
        <section class="sp-section">
          <div class="h2-feature-eyebrow">About This {{ showType or 'Show' }}</div>
          <h2 class="sp-section-heading">{{ title }}</h2>
          <div class="sp-description">{{ description | safe }}</div>
          {{ content | safe }}
        </section>

        <!-- Performers -->
        {%- if performers and performers.length -%}
        <section class="sp-section">
          <div class="h2-feature-eyebrow">Lineup</div>
          <h2 class="sp-section-heading">Tonight's Performers</h2>
          <div class="sp-performers">
            {%- for p in performers -%}
            <div class="sp-performer">
              {%- if p.photo -%}
              <img src="{{ p.photo | netlifyImg(300) }}" alt="{{ p.name }}" class="sp-performer-photo" loading="lazy" decoding="async">
              {%- else -%}
              <div class="sp-performer-avatar" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7"/></svg>
              </div>
              {%- endif -%}
              <div class="sp-performer-info">
                <span class="sp-performer-name">{{ p.name }}</span>
                {%- if p.instagram -%}
                <a href="{{ p.instagram }}" class="sp-performer-ig" target="_blank" rel="noopener">@{{ p.instagram | replace('https://instagram.com/', '') | replace('https://www.instagram.com/', '') | replace('/', '') }}</a>
                {%- endif -%}
              </div>
            </div>
            {%- endfor -%}
          </div>
        </section>
        {%- endif -%}

        <!-- SEO content -->
        <section class="sp-section sp-seo">
          <div class="h2-feature-eyebrow">Live Stand-Up Comedy in Philadelphia</div>
          <p>Join us for an unforgettable evening of live stand-up comedy at {{ location.name }} in the heart of Center City Philadelphia. {{ title }}{% if subtitle %} &mdash; {{ subtitle }}{% endif %} is the perfect date night or night out with friends. Located at {{ location.streetAddress }}, our intimate venue offers a cozy atmosphere with great food and drinks. 21+ only.</p>
        </section>

      </main>

      <!-- Sidebar -->
      <aside class="sp-sidebar" aria-label="Show details">

        <!-- Tickets -->
        <div class="sp-card">
          <div class="h2-feature-eyebrow">Tickets</div>
          <div class="sp-card-tickets">
            {%- for st in showtimes -%}
              {%- if st.ticketAvailability == "https://schema.org/InStock" and st.ticketUrl -%}
              <a
                href="{{ st.ticketUrl }}"
                class="h2-ticket-btn h2-ticket-btn--featured"
                target="_blank"
                rel="noopener"
                onclick="gtag('event', 'ticket_click', {'event_category': 'Tickets', 'event_label': '{{ title }} {{ st.startDate | showTimeOnly }}', 'transport_type': 'beacon'});"
              >{{ st.startDate | showTimeOnly }} Tickets &rarr;</a>
              {%- elif st.ticketAvailability == "https://schema.org/SoldOut" -%}
              <span class="h2-ticket-unavailable">{{ st.startDate | showTimeOnly }} &mdash; Sold Out</span>
              {%- else -%}
              <span class="h2-ticket-unavailable">Coming Soon</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if not (showtimes | allSoldOut) -%}
          <div class="mc-scarcity" role="status" style="margin-top:12px;">
            <div class="mc-scarcity-dot" aria-hidden="true"></div>
            <span class="mc-scarcity-text">Selling fast &mdash; limited seats</span>
          </div>
          {%- endif -%}
        </div>

        <!-- Date & Time -->
        <div class="sp-card">
          <div class="h2-feature-eyebrow">Date &amp; Time</div>
          <p class="sp-card-value">{{ showtimes[0].startDate | showDayOfWeek }}, {{ showtimes[0].startDate | showDateOnly }}</p>
          <p class="sp-card-sub">
            {%- for st in showtimes -%}{{ st.startDate | showTimeOnly }}{% if not loop.last %} &amp; {% endif %}{%- endfor -%}
          </p>
        </div>

        <!-- Venue -->
        <div class="sp-card">
          <div class="h2-feature-eyebrow">Venue</div>
          <p class="sp-card-value">{{ location.name }}</p>
          <a
            href="https://maps.google.com/?q={{ location.streetAddress }},+{{ location.city }}+{{ location.state }}+{{ location.postalCode }}"
            class="sp-card-sub sp-card-link"
            target="_blank"
            rel="noopener"
          >{{ location.streetAddress }}, {{ location.city }} {{ location.state }} {{ location.postalCode }}</a>
        </div>

        <!-- Show details -->
        <div class="sp-card">
          <div class="h2-feature-eyebrow">Details</div>
          <ul class="sp-details-list">
            {%- if ageRestriction -%}<li><strong>Age:</strong> {{ ageRestriction }}</li>{%- endif -%}
            {%- if showType -%}<li><strong>Format:</strong> {{ showType }}</li>{%- endif -%}
            <li><strong>Duration:</strong> 75&ndash;90 min</li>
            <li><strong>Seating:</strong> First come, first served</li>
            <li><strong>Doors:</strong> 30 min before showtime</li>
            <li><strong>Minimum:</strong> 2-item (food &amp; drinks)</li>
          </ul>
        </div>

      </aside>

    </div>
  </div><!-- /.sp-body -->

  {%- include "h2-footer.njk" -%}

</div><!-- /.sp-page -->

<script>
  (function () {
    // Nav
    const btn = document.querySelector('.h2-hamburger');
    const menu = document.getElementById('h2-nav-menu');
    if (btn && menu) {
      btn.addEventListener('click', function () {
        const open = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!open));
        menu.classList.toggle('is-open');
      });
      menu.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          btn.setAttribute('aria-expanded', 'false');
          menu.classList.remove('is-open');
        });
      });
    }

    // Carousel
    var track = document.querySelector('.sp-carousel-track');
    if (!track) return;
    var slides = Array.from(track.querySelectorAll('.sp-carousel-slide'));
    var dots   = Array.from(document.querySelectorAll('.sp-carousel-dot'));
    var prevBtn = document.querySelector('.sp-carousel-btn--prev');
    var nextBtn = document.querySelector('.sp-carousel-btn--next');
    var current = 0;
    var autoTimer;

    function goTo(index) {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      if (dots[current]) { dots[current].classList.remove('is-active'); dots[current].setAttribute('aria-selected', 'false'); }
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      if (dots[current]) { dots[current].classList.add('is-active'); dots[current].setAttribute('aria-selected', 'true'); }
    }

    function startAuto() { autoTimer = setInterval(function () { goTo(current + 1); }, 4500); }
    function stopAuto()  { clearInterval(autoTimer); }

    if (prevBtn) prevBtn.addEventListener('click', function () { stopAuto(); goTo(current - 1); startAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { stopAuto(); goTo(current + 1); startAuto(); });
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () { stopAuto(); goTo(parseInt(this.dataset.index)); startAuto(); });
    });

    // Swipe
    var touchStartX = 0;
    track.addEventListener('touchstart', function (e) { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) { stopAuto(); goTo(dx < 0 ? current + 1 : current - 1); startAuto(); }
    }, { passive: true });

    startAuto();
  })();
</script>
