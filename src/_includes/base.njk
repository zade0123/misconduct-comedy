<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="{{ metaDescription or description }}"/>
        <meta property="og:title" content="{{ metaTitle or title }}"/>
        <meta property="og:description" content="{{ metaDescription or description }}"/>
        <meta property="og:type" content="website"/>
        <meta property="og:image" content="/images/Logo Final 1000px.png"/>
        <meta property="og:image:secure_url" content="/images/Logo Final 1000px.png"/>

        <link rel="apple-touch-icon" sizes="180x180" href="/images/logo 100px.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/images/logo 100px.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/images/logo 100px.png">
        <link rel="preload" as="font" href="/fonts/dm-sans-latin.woff2" type="font/woff2" crossorigin>
        <link rel="preload" as="font" href="/fonts/dm-sans-italic-latin.woff2" type="font/woff2" crossorigin>
        <link rel="preload" as="font" href="/fonts/fontdiner-swanky-latin.woff2" type="font/woff2" crossorigin>
        <link rel="stylesheet" href="/css/root.css">
        <link rel="stylesheet" href="/css/{{ stylesheet or 'index.css' }}">

        <!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-N6ZWBDHV');</script>
        <!-- End Google Tag Manager -->

        <!-- Google tag (gtag.js) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-H7GJ0KWS9R"></script>
        <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-H7GJ0KWS9R');
        </script>
        
        {% if generateShowSchema and collections.showsByDate %}
        <!-- Google Event Schema -->
        <script type="application/ld+json">
        {{ collections.showsByDate | eventSchema | safe }}
        </script>
        {% endif %}
        
        <title>{{ pageTitle or title }}</title>
    </head>
    <body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
        <!-- Google Tag Manager (noscript) -->
        <noscript>
            <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N6ZWBDHV" height="0" width="0" style="display:none;visibility:hidden"></iframe>
        </noscript>
        <!-- End Google Tag Manager (noscript) -->
        
        {{ content | safe }}
    </body>
</html>
