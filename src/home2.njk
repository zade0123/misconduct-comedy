  <section class="h2-section h2-shows" id="shows">
    <div class="h2-section-inner">

      <div class="h2-section-header">
        <div class="mc-topper">
          <div class="mc-topper-rule" aria-hidden="true"></div>
          <span class="mc-topper-text">Live Stand-Up</span>
        </div>
        <h2 class="h2-section-heading">Upcoming Shows</h2>
        <p class="h2-shows-subline">Tickets sell out &mdash; don&rsquo;t wait.</p>
      </div>

      <div class="h2-shows-layout">
        {%- for show in collections.showsByDate -%}
        {%- if loop.first -%}

        <!-- Featured: next show -->
        <article class="h2-show-featured{% if show.data.showtimes | allSoldOut %} h2-show-card--soldout{% endif %}">

          <div class="h2-show-featured-img">
            {%- if show.data.images and show.data.images.length -%}
            <img src="{{ show.data.images[0].src }}" alt="{{ show.data.images[0].alt or show.data.title }}" loading="lazy" decoding="async">
            {%- endif -%}
          </div>

          <div class="h2-show-featured-body">

            <div class="h2-show-featured-badges">
              <span class="h2-show-badge h2-show-badge--next">Next Show</span>
              {%- if show.data.showType %}<span class="h2-show-badge">{{ show.data.showType }}</span>{%- endif -%}
              {%- if show.data.ageRestriction %}<span class="h2-show-badge">{{ show.data.ageRestriction }}</span>{%- endif -%}
            </div>

            <h3 class="h2-show-featured-title">
              <a href="{{ show.url }}" class="h2-show-link">{{ show.data.title }}</a>
            </h3>

            {%- if show.data.subtitle -%}
            <p class="h2-show-featured-sub">{{ show.data.subtitle }}</p>
            {%- endif -%}

            <div class="h2-show-featured-meta">
              <div class="h2-show-featured-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {{ show.data.showtimes[0].startDate | showDayOfWeek }}, {{ show.data.showtimes[0].startDate | showDateOnly }}
                &nbsp;&middot;&nbsp;
                {%- for st in show.data.showtimes -%}{{ st.startDate | showTimeOnly }}{% if not loop.last %} &amp; {% endif %}{%- endfor -%}
              </div>
              <div class="h2-show-featured-price">
                From <strong>${{ show.data.showtimes[0].ticketPrice | int }}</strong>
              </div>
            </div>

            {%- if not (show.data.showtimes | allSoldOut) -%}
            <div class="mc-scarcity h2-show-featured-scarcity" role="status">
              <div class="mc-scarcity-dot" aria-hidden="true"></div>
              <span class="mc-scarcity-text">Selling fast &mdash; limited seats available</span>
            </div>
            {%- endif -%}

            <div class="h2-show-featured-tickets">
              {%- for st in show.data.showtimes -%}
                {%- if st.ticketAvailability == "https://schema.org/InStock" and st.ticketUrl -%}
                <a
                  href="{{ st.ticketUrl }}"
                  class="h2-ticket-btn h2-ticket-btn--featured"
                  target="_blank"
                  rel="noopener"
                  onclick="gtag('event', 'ticket_click', {'event_category': 'Tickets', 'event_label': '{{ show.data.title }} {{ st.startDate | showTimeOnly }}', 'transport_type': 'beacon'});"
                >Get Tickets &mdash; {{ st.startDate | showTimeOnly }} &rarr;</a>
                {%- elif st.ticketAvailability == "https://schema.org/SoldOut" -%}
                <span class="h2-ticket-unavailable">{{ st.startDate | showTimeOnly }} &mdash; Sold Out</span>
                {%- else -%}
                <span class="h2-ticket-unavailable">Coming Soon</span>
                {%- endif -%}
              {%- endfor -%}
            </div>

            <div class="h2-show-featured-proof">
              <div class="mc-stars" aria-label="5 out of 5 stars">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#c9a96e" aria-hidden="true"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#c9a96e" aria-hidden="true"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#c9a96e" aria-hidden="true"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#c9a96e" aria-hidden="true"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
                <svg width="11" height="11" viewBox="0 0 24 24" fill="#c9a96e" aria-hidden="true"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
              </div>
              <span class="h2-show-featured-review">&ldquo;Absolutely hilarious &mdash; best night out in Philly&rdquo;</span>
            </div>

          </div>
        </article>

        {%- else -%}

        <!-- Compact row: additional shows -->
        <article class="h2-show-compact{% if show.data.showtimes | allSoldOut %} h2-show-card--soldout{% endif %}">

          <div class="h2-show-compact-img">
            {%- if show.data.images and show.data.images.length -%}
            <img src="{{ show.data.images[0].src }}" alt="{{ show.data.images[0].alt or show.data.title }}" loading="lazy" decoding="async">
            {%- endif -%}
          </div>

          <div class="h2-show-compact-body">
            <div class="h2-show-compact-info">
              {%- if show.data.showType %}<span class="h2-show-eyebrow">{{ show.data.showType }}</span>{%- endif -%}
              <h3 class="h2-show-compact-title">
                <a href="{{ show.url }}" class="h2-show-link">{{ show.data.title }}</a>
              </h3>
              <div class="h2-show-compact-when">
                {{ show.data.showtimes[0].startDate | showDayOfWeek }}, {{ show.data.showtimes[0].startDate | showDateOnly }}
                &nbsp;&middot;&nbsp;
                {%- for st in show.data.showtimes -%}{{ st.startDate | showTimeOnly }}{% if not loop.last %} &amp; {% endif %}{%- endfor -%}
                &nbsp;&middot;&nbsp; From <strong>${{ show.data.showtimes[0].ticketPrice | int }}</strong>
              </div>
            </div>
            <div class="h2-show-compact-tickets">
              {%- for st in show.data.showtimes -%}
                {%- if st.ticketAvailability == "https://schema.org/InStock" and st.ticketUrl -%}
                <a
                  href="{{ st.ticketUrl }}"
                  class="h2-ticket-btn"
                  target="_blank"
                  rel="noopener"
                  onclick="gtag('event', 'ticket_click', {'event_category': 'Tickets', 'event_label': '{{ show.data.title }} {{ st.startDate | showTimeOnly }}', 'transport_type': 'beacon'});"
                >{{ st.startDate | showTimeOnly }} &rarr;</a>
                {%- elif st.ticketAvailability == "https://schema.org/SoldOut" -%}
                <span class="h2-ticket-unavailable">{{ st.startDate | showTimeOnly }} &mdash; Sold Out</span>
                {%- else -%}
                <span class="h2-ticket-unavailable">Coming Soon</span>
                {%- endif -%}
