---
layout: base.njk
title: Blog - Misconduct Comedy
metaTitle: Misconduct Comedy Blog
metaDescription: Latest updates, news, and stories from Misconduct Comedy
permalink: /blog/index.html
---

<style>
.blog-header {
    max-width: 900px;
    margin: 4rem auto 2rem;
    padding: 0 2rem;
    text-align: center;
}

.blog-header h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
}

.blog-list {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
}

.blog-item {
    background: white;
    padding: 2rem;
    margin-bottom: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.blog-item h2 {
    margin-top: 0;
}

.blog-item h2 a {
    color: #333;
    text-decoration: none;
}

.blog-item h2 a:hover {
    color: #e74c3c;
}

.blog-meta {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 1rem;
}

.blog-excerpt {
    line-height: 1.6;
    margin-bottom: 1rem;
}

.read-more {
    color: #e74c3c;
    text-decoration: none;
    font-weight: bold;
}

.read-more:hover {
    text-decoration: underline;
}
</style>

<div class="blog-header">
    <h1>Blog</h1>
    <p>Latest updates, news, and stories from Misconduct Comedy</p>
</div>

<div class="blog-list">
    {%- for post in collections.blog | reverse -%}
    <article class="blog-item">
        {% if post.data.featuredImage %}
        <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" style="width: 100%; border-radius: 8px; margin-bottom: 1rem;">
        {% endif %}
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <div class="blog-meta">
            Published on {{ post.data.date | date }}
        </div>
        <div class="blog-excerpt">
            {{ post.data.excerpt }}
        </div>
        <a href="{{ post.url }}" class="read-more">Read More →</a>
    </article>
    {%- else -%}
    <p>No blog posts yet. Check back soon!</p>
    {%- endfor -%}
</div>
