    </div>
  </section><!-- /.h2-about -->

  </main>

  {%- include "h2-footer.njk" -%}

  <!-- ══════════════════════════════════════
       MOBILE STICKY TICKET BAR
  ══════════════════════════════════════ -->
  {%- if heroShow -%}
  <div class="h2-sticky-ticket-bar">
    <div class="h2-sticky-ticket-content">
      <div class="h2-sticky-ticket-info">
        <div class="h2-sticky-ticket-label">Next Show</div>
        <div class="h2-sticky-ticket-date">{{ heroShow.data.showtimes[0].startDate | showDayOfWeek }}, {{ heroShow.data.showtimes[0].startDate | showDateOnly }}</div>
      </div>
      {%- set heroTicketUrl = null -%}
      {%- for st in heroShow.data.showtimes -%}
        {%- if st.ticketUrl and not heroTicketUrl -%}{%- set heroTicketUrl = st.ticketUrl -%}{%- endif -%}
      {%- endfor -%}
      <a href="{{ heroTicketUrl or heroShow.url }}" class="h2-sticky-ticket-btn"{% if heroTicketUrl %} target="_blank" rel="noopener"{% endif %}>Get Tickets</a>
    </div>
  </div>
  {%- endif -%}

</div><!-- /.h2-page -->

<script>
  (function () {
    const btn = document.querySelector('.h2-hamburger');
    const menu = document.getElementById('h2-nav-menu');

    btn.addEventListener('click', function () {
      const open = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('is-open');
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        btn.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
      });
    });

    // Video player controls
    const videoReels = document.querySelectorAll('.h2-video-reel');
    
    videoReels.forEach(function (reel) {
      const video = reel.querySelector('.h2-video-player');
      const playBtn = reel.querySelector('.h2-video-play-btn');
      
      // Play button click
      playBtn.addEventListener('click', function () {
        video.muted = false;
        video.setAttribute('controls', 'controls');
        video.play();
        reel.classList.add('is-playing');
      });
      
      // Click video to pause (controls will handle this now)
      // Removed manual click handler since controls are now visible
      
      // Show play button when video ends
      video.addEventListener('ended', function () {
        reel.classList.remove('is-playing');
      });
      
      // Show play button when video is paused
      video.addEventListener('pause', function () {
        reel.classList.remove('is-playing');
      });
      
      // Hide play button when video is playing
      video.addEventListener('play', function () {
        reel.classList.add('is-playing');
      });
    });
  })();
</script>
