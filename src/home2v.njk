  <!-- ══════════════════════════════════════
       UPCOMING SHOWS
  ══════════════════════════════════════ -->
  <section class="h2-section h2-shows" id="shows">
    <div class="h2-section-inner">

      <div class="h2-section-header">
        <div class="mc-topper">
          <div class="mc-topper-rule" aria-hidden="true"></div>
          <span class="mc-topper-text">Live Stand-Up</span>
        </div>
        <h2 class="h2-section-heading">Upcoming Shows</h2>
      </div>

      <div class="h2-show-list">
        {%- for show in collections.showsByDate -%}
        <article class="h2-show-row{% if show.data.showtimes | allSoldOut %} h2-show-row--soldout{% endif %}">

          <div class="h2-show-row-thumb">
            {%- if show.data.images and show.data.images.length -%}
            <img src="{{ show.data.images[0].src }}" alt="{{ show.data.images[0].alt or show.data.title }}" loading="lazy" decoding="async">
            {%- endif -%}
          </div>

          <div class="h2-show-row-body">
            <div class="h2-show-row-info">
              {%- if show.data.subtitle -%}
              <span class="h2-show-eyebrow">{{ show.data.subtitle }}</span>
              {%- endif -%}
              <h3 class="h2-show-title">
                <a href="{{ show.url }}" class="h2-show-link">{{ show.data.title }}</a>
              </h3>
              <div class="h2-show-meta">
                <span class="h2-show-tag">{{ show.data.showtimes[0].startDate | showDayOfWeek }}, {{ show.data.showtimes[0].startDate | showDateOnly }}</span>
                {%- if show.data.showType %}<span class="h2-show-tag">{{ show.data.showType }}</span>{%- endif -%}
                {%- if show.data.ageRestriction %}<span class="h2-show-tag">{{ show.data.ageRestriction }}</span>{%- endif -%}
              </div>
              <div class="mc-date-price h2-show-price-bar">
                <div class="mc-dp-cell mc-dp-cell--date">
                  <div class="mc-dp-label">Time</div>
                  <div class="mc-dp-value">
                    {%- for st in show.data.showtimes -%}
                      {{ st.startDate | showTimeOnly }}{% if not loop.last %} &amp; {% endif %}
                    {%- endfor -%}
                  </div>
                </div>
                <div class="mc-dp-divider" aria-hidden="true"></div>
                <div class="mc-dp-cell mc-dp-cell--price">
                  <div class="mc-dp-label">From</div>
                  <div class="mc-dp-value mc-dp-value--price">${{ show.data.showtimes[0].ticketPrice | int }}</div>
                </div>
              </div>
            </div>

            <div class="h2-show-row-tickets">
              {%- for st in show.data.showtimes -%}
                {%- if st.ticketAvailability == "https://schema.org/InStock" and st.ticketUrl -%}
                <a
                  href="{{ st.ticketUrl }}"
                  class="h2-ticket-btn"
                  target="_blank"
                  rel="noopener"
                  onclick="gtag('event', 'ticket_click', {'event_category': 'Tickets', 'event_label': '{{ show.data.title }} {{ st.startDate | showTimeOnly }}', 'transport_type': 'beacon'});"
                >{{ st.startDate | showTimeOnly }} Tickets &rarr;</a>
                {%- elif st.ticketAvailability == "https://schema.org/SoldOut" -%}
                <span class="h2-ticket-unavailable">{{ st.startDate | showTimeOnly }} &mdash; Sold Out</span>
                {%- else -%}
                <span class="h2-ticket-unavailable">Coming Soon</span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div><!-- /.h2-show-row-body -->

        </article>
        {%- else -%}
        <p class="h2-no-shows">No shows scheduled yet. Check back soon!</p>
        {%- endfor -%}
      </div>

    </div>
  </section><!-- /.h2-shows -->


  <!-- ══════════════════════════════════════
