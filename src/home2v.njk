  <section class="h2-section h2-about" id="about">
    <div class="h2-section-inner">

      <!-- Centered intro block -->
      <div class="h2-about-intro-block">
        <div class="mc-topper h2-mc-topper--center">
          <div class="mc-topper-rule" aria-hidden="true"></div>
          <span class="mc-topper-text">The Lowdown</span>
          <div class="mc-topper-rule" aria-hidden="true"></div>
        </div>
        <h2 class="h2-section-heading">About Misconduct Comedy</h2>
        <p class="h2-about-intro">Misconduct Comedy brings you Philadelphia's best stand-up comedy in the heart of Center City. Whether it's the perfect date night or a fun hang with friends, our shows feature local favorites and rising stars in an intimate, laid-back setting.</p>
      </div>

      <!-- Stats highlights -->
      <div class="h2-stats-row" aria-label="Show highlights">
        <div class="h2-stat">
          <span class="h2-stat-num">75&ndash;90</span>
          <span class="h2-stat-label">Minutes per show</span>
        </div>
        <div class="h2-stat">
          <span class="h2-stat-num">5&ndash;7</span>
          <span class="h2-stat-label">Comedians per night</span>
        </div>
        <div class="h2-stat">
          <span class="h2-stat-num">21+</span>
          <span class="h2-stat-label">Age requirement</span>
        </div>
        <div class="h2-stat">
          <span class="h2-stat-num">$15</span>
          <span class="h2-stat-label">Tickets from</span>
        </div>
      </div>

      <!-- 3-col feature bar -->
      <div class="h2-features-bar">

        <div class="h2-feature">
          <div class="h2-feature-eyebrow">The Venue</div>
          <h3>Misconduct Tavern</h3>
          <p>
            <a href="https://maps.google.com/?q=1511+Locust+Street,+Philadelphia+PA+19102" target="_blank" rel="noopener">1511 Locust St, Philadelphia PA 19102</a><br>
            Cozy bar with a full drink menu &amp; great atmosphere for stand-up.
          </p>
        </div>

        <div class="h2-feature">
          <div class="h2-feature-eyebrow">Show Details</div>
          <h3>Good to Know</h3>
          <p>
            <strong>Seating:</strong> First come, first served<br>
            <strong>Doors:</strong> 30 min before showtime<br>
            <strong>Bar:</strong> Full menu &middot; 2-item minimum
          </p>
        </div>

        <div class="h2-feature">
          <div class="h2-feature-eyebrow">Reach Out</div>
          <h3>Get in Touch</h3>
          <p>
            Questions? Booking a group?<br>
            <a href="mailto:hausofcomedy@gmail.com">hausofcomedy@gmail.com</a><br>
            <a href="https://www.instagram.com/misconductcomedy" target="_blank" rel="noopener">@misconductcomedy</a>
          </p>
        </div>

      </div><!-- /.h2-features-bar -->

      <div class="h2-about-cta-row">
        <a href="#shows" class="h2-about-cta">See Upcoming Shows &rarr;</a>
      </div>

    </div>
  </section><!-- /.h2-about -->

