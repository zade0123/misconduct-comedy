      <li><button class="h2-font-picker-option" data-font="Fontdiner Swanky" style="font-family:'Fontdiner Swanky',cursive;" role="option">Fontdiner Swanky</button></li>
      <li><button class="h2-font-picker-option" data-font="Cookie" style="font-family:'Cookie',cursive;" role="option">Cookie</button></li>
    </ul>
    <button class="h2-font-picker-btn" id="h2-font-picker-btn" aria-haspopup="listbox" aria-expanded="false" aria-controls="h2-font-picker-list">
      <span id="h2-font-picker-label">Aa &mdash; Oregano</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
