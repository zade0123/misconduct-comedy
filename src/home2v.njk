<script>
  (function () {
    const btn = document.querySelector('.h2-hamburger');
    const menu = document.getElementById('h2-nav-menu');

    btn.addEventListener('click', function () {
      const open = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('is-open');
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        btn.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
      });
    });
  })();
</script>

<script>
  (function () {
    var pickerBtn  = document.getElementById('h2-font-picker-btn');
    var pickerList = document.getElementById('h2-font-picker-list');
    var pickerLabel = document.getElementById('h2-font-picker-label');
    var headlines  = document.querySelectorAll('.mc-headline, .h2-section-heading, .h2-stat-num');

    // Toggle open/close
    pickerBtn.addEventListener('click', function () {
      var open = pickerList.classList.toggle('is-open');
      pickerBtn.setAttribute('aria-expanded', String(open));
    });

    // Close when clicking outside
    document.addEventListener('click', function (e) {
      if (!document.getElementById('h2-font-picker').contains(e.target)) {
        pickerList.classList.remove('is-open');
        pickerBtn.setAttribute('aria-expanded', 'false');
      }
    });

    // Handle font selection
    pickerList.addEventListener('click', function (e) {
      var option = e.target.closest('.h2-font-picker-option');
      if (!option) return;

      var font    = option.dataset.font;
      var isItalic = option.dataset.italic === 'true';

      headlines.forEach(function (el) {
        el.style.fontFamily  = "'" + font + "', cursive";
        el.style.fontStyle   = isItalic ? 'italic' : 'normal';
      });

      pickerList.querySelectorAll('.h2-font-picker-option').forEach(function (o) {
        o.classList.toggle('is-active', o === option);
      });

      pickerLabel.textContent = 'Aa \u2014 ' + font;
      pickerList.classList.remove('is-open');
      pickerBtn.setAttribute('aria-expanded', 'false');
    });
  })();
</script>
